[Unit]
Description=Big A Angels Tracker
After=network-online.target multi-user.target biga-connectivity.service
Wants=network-online.target
Requires=biga-connectivity.service
# Scoreboard runs when WiFi is provisioned and not in add-network / offline mode.
ConditionPathExists=/etc/biga/wifi_creds.json
ConditionPathExists=!/etc/biga/provisioning_active

[Service]
Type=simple
User=root
WorkingDirectory=/home/pi/BigA
# Pull latest code before launching — ensures fresh images have all updates
# on first run without waiting for the 4am cron. The leading '-' means a
# failed update (no network yet, git error, etc.) is non-fatal; biga still starts.
ExecStartPre=-/bin/bash /home/pi/BigA/scripts/update_biga.sh
ExecStart=/usr/local/bin/biga-start.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target